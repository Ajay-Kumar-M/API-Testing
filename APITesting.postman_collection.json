    {
      "name": "Submit an order",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function(){",
              "    pm.response.to.have.status(201);",
              "})",
              "",
              "const response = pm.response.json();",
              "",
              "pm.test(\"Key 'orderId' exists\", function () {",
              "    pm.expect(response).to.have.property(\"orderId\");",
              "    pm.expect(response.orderId).to.not.be.undefined;",
              "});",
              "",
              "pm.test(\"orderId is present and not empty\", function () {",
              "    pm.expect(response.orderId).to.exist;",
              "    pm.expect(response.orderId).to.not.be.null;",
              "    pm.expect(response.orderId).to.not.eql(\"\");",
              "});",
              "",
              "pm.test(\"orderId is present and not empty\", function () {",
              "    pm.expect(response).to.have.property(\"orderId\").that.is.not.empty;",
              "});",
              "",
              "if(response.orderId){",
              "    pm.globals.set(\"orderID\",response.orderId);",
              "}",
              "",
              "/*",
              "pm.test(\"Email valid\", function () {",
              "    let email = jsonData.email;",
              "    pm.expect(email).to.not.be.oneOf([null, undefined, \"\"]);",
              "});",
              "*/"
            ],
