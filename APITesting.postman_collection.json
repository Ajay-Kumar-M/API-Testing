  "item": [
    {
      "name": "Sample Status",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function(){",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Status code is 201\", function(){",
              "    pm.response.to.have.status(\"OK\");",
              "});",
              "",
              "const response = pm.response.json();",
              "console.log(response.status);",
              "console.log(response['status']);",
              "pm.test(\"Response Status should be OK\", () => {",
              "    pm.expect(response.status).to.eql(\"OK\");",
              "});",
              "",
              "pm.test(\"Header Content Type\", () => {",
              "\tpm.response.to.have.header(\"Content-Type\");",
              "});",
              "",
              "pm.test(\"Header Content Type is JSON\", () => {",
              "\tpm.expect(pm.response.headers.get('Content-Type')).to.eql('application/json');",
              "});",
              "",
              "pm.test(\"ResponseTime\", () => {",
              "\tpm.expect(pm.response.responseTime).to.be.below(1000);",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseURL}}/status",
          "host": [
            "{{baseURL}}"
          ],
          "path": [
            "status"
          ]
        }
      },
      "response": []
    },
    {
      "name": "list of books",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function(){",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const response = pm.response.json();",
              "console.log(response);",
              "const availableBooks = response.filter((book) => book.available === true);",
              "",
              "const book = availableBooks[0];",
              "pm.test(\"available book found\", () => {",
              "    pm.expect(book).to.be.an('object');",
              "    pm.expect(book.available).to.be.true;",
              "});",
              "",
              "console.log(book.id);",
              "if(book){",
              "    pm.globals.set(\"bookID\",book.id);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseURL}}/books",
          "host": [
            "{{baseURL}}"
          ],
          "path": [
            "books"
          ],
          "query": [
            {
              "key": "type",
              "value": "fiction",
              "disabled": true
            },
            {
              "key": "limit",
              "value": "1",
              "disabled": true
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "list of fiction books",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function(){",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const response = pm.response.json();",
              "console.log(response);",
              "",
              "pm.test(\"Response is an array\", function () {",
              "    pm.expect(response).to.be.an(\"array\").that.is.not.empty;",
              "});",
              "",
              "pm.test(\"All books are of type Fiction\", function () {",
              "    response.forEach(item => {",
              "        pm.expect(item.type).to.eql(\"fiction\");",
              "    });",
              "});",
              "",
              "",
              "let accessToken = pm.collectionVariables.get(\"accessToken\");",
              "if (accessToken && accessToken.trim() !== \"\") {",
              "    pm.execution.setNextRequest(\"Get a single book\");",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseURL}}/books?type=fiction",
          "host": [
            "{{baseURL}}"
          ],
